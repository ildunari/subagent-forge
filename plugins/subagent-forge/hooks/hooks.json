{
  "description": "Guard against destructive Bash commands",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/guard_destructive_bash.py"
          }
        ]
      }
    ]
  }
}
